<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Wolf.Desktop.ViewModels"
             xmlns:dto="using:Wolf.Dtos"
             x:Class="Wolf.Desktop.Views.EmployeesView"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSurface}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BrushBorder}"
                Height="52">
            <Grid ColumnDefinitions="*,Auto" Margin="24,0">
                <TextBlock Text="Служители"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Border Background="{StaticResource BrushSurfaceAlt}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Width="260">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox Text="{Binding SearchText}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     Watermark="Търсене на служители..."
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== EMPLOYEE TABLE ===== -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="44,*,120,180,80,65"
                  Background="{StaticResource BrushSurfaceAlt}"
                  Height="32">
                <TextBlock Grid.Column="0" Text="#"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBlock Grid.Column="1" Text="ИМЕ"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="ТЕЛЕФОН"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="3" Text="ИМЕЙЛ"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="4" Text="ТИП"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="4,0"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredEmployees}"
                     SelectedItem="{Binding SelectedEmployee}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="dto:EmployeeDto">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrushBorder}">
                            <Grid ColumnDefinitions="44,*,120,180,80,65"
                                  MinHeight="36"
                                  Background="Transparent">
                                <Grid.Styles>
                                    <Style Selector="Grid:pointerover">
                                        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
                                    </Style>
                                </Grid.Styles>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Employeeid}"
                                           FontFamily="IBM Plex Mono, Consolas"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="1"
                                           FontWeight="SemiBold"
                                           FontSize="12.5"
                                           VerticalAlignment="Center"
                                           Margin="4,0"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding Firstname}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Secondname}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Lastname}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Phone}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Email}"
                                           Foreground="#3b6fa0"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Outsider/Staff badge -->
                                <Panel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border CornerRadius="12" Padding="8,2"
                                            IsVisible="{Binding Outsider}"
                                            Background="#fdf6e3">
                                        <TextBlock Text="Външен" FontSize="10" FontWeight="SemiBold" Foreground="#b8860b"/>
                                    </Border>
                                    <Border CornerRadius="12" Padding="8,2"
                                            IsVisible="{Binding !Outsider}"
                                            Background="#edf5ee">
                                        <TextBlock Text="Щатен" FontSize="10" FontWeight="SemiBold" Foreground="#3a7d44"/>
                                    </Border>
                                </Panel>
                                <!-- Stats button (admin only) -->
                                <Button Grid.Column="5"
                                        Classes="icon sm"
                                        Command="{Binding $parent[UserControl].DataContext.ViewStatsCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Преглед статистика"
                                        IsVisible="{Binding $parent[UserControl].DataContext.IsAdmin}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="&#x1F4CA;" FontSize="13"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detail panel -->
            <Border Grid.Row="2"
                    IsVisible="{Binding SelectedEmployee, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="{StaticResource BrushSurfaceAlt}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushBorder}"
                    Padding="20,12,20,16" MaxHeight="220">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <Button Classes="icon sm"
                                HorizontalAlignment="Right"
                                Margin="0,-4,0,0"
                                ToolTip.Tip="Свиване"
                                Command="{Binding DeselectEmployeeCommand}">
                            <TextBlock Text="&#x25B2;" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                        </Button>

                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,24,8" Width="100">
                                <TextBlock Text="ИД СЛУЖИТЕЛ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Employeeid, StringFormat='#{0}'}"
                                           FontFamily="IBM Plex Mono, Consolas" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140">
                                <TextBlock Text="ИМЕ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Firstname}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140"
                                        IsVisible="{Binding SelectedEmployee.Secondname, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ПРЕЗИМЕ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Secondname}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140">
                                <TextBlock Text="ФАМИЛИЯ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Lastname}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140"
                                        IsVisible="{Binding SelectedEmployee.Phone, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ТЕЛЕФОН" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Phone}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="200"
                                        IsVisible="{Binding SelectedEmployee.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ИМЕЙЛ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedEmployee.Email}" FontSize="12.5" Foreground="#3b6fa0"/>
                            </StackPanel>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsAdmin}">
                            <Button Classes="sm primary"
                                    Command="{Binding ViewStatsCommand}"
                                    CommandParameter="{Binding SelectedEmployee}">
                                &#x1F4CA; Преглед статистика
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
