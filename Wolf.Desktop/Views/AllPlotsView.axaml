<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Wolf.Desktop.ViewModels"
             xmlns:dto="using:Wolf.Dtos"
             x:Class="Wolf.Desktop.Views.AllPlotsView"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSurface}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BrushBorder}"
                Height="52">
            <Grid ColumnDefinitions="*,Auto" Margin="24,0">
                <TextBlock Text="Имоти"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Border Background="{StaticResource BrushSurfaceAlt}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Width="260">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox Text="{Binding SearchText}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     Watermark="Търсене на имоти..."
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Classes="primary sm"
                            Command="{Binding NewPlotCommand}">
                        + Нов имот
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== PLOT TABLE ===== -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="44,80,80,100,100,120,100,65"
                  Background="{StaticResource BrushSurfaceAlt}" Height="32">
                <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBlock Grid.Column="1" Text="ИМОТ №" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="РЕГ. №" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="3" Text="ГРАД" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="4" Text="ОБЩИНА" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="5" Text="ОБОЗНАЧЕНИЕ" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="6" Text="УЛИЦА" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="4,0"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredPlots}"
                     SelectedItem="{Binding SelectedPlot}"
                     Background="Transparent" BorderThickness="0" Padding="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="dto:PlotDto">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrushBorder}">
                            <Grid ColumnDefinitions="44,80,80,100,100,120,100,65"
                                  MinHeight="36" Background="Transparent">
                                <Grid.Styles>
                                    <Style Selector="Grid:pointerover">
                                        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
                                    </Style>
                                </Grid.Styles>
                                <TextBlock Grid.Column="0" Text="{Binding Plotid}"
                                           FontFamily="IBM Plex Mono, Consolas"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Plotnumber}"
                                           FontWeight="SemiBold" FontSize="12.5"
                                           VerticalAlignment="Center" Margin="4,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Regulatedplotnumber}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding City}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="{Binding Municipality}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="5" Text="{Binding Designation}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="6" Text="{Binding Street}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="2"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Classes="icon sm" ToolTip.Tip="Редактиране"
                                            Command="{Binding $parent[UserControl].DataContext.EditPlotCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#x270F;&#xFE0F;" FontSize="13"/>
                                    </Button>
                                    <Button Classes="icon sm" ToolTip.Tip="Изтриване"
                                            Command="{Binding $parent[UserControl].DataContext.DeletePlotCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#x1F5D1;&#xFE0F;" FontSize="13"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detail panel -->
            <Border Grid.Row="2"
                    IsVisible="{Binding SelectedPlot, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="{StaticResource BrushSurfaceAlt}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushBorder}"
                    Padding="20,12,20,16" MaxHeight="220">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <Button Classes="icon sm" HorizontalAlignment="Right" Margin="0,-4,0,0"
                                ToolTip.Tip="Свиване"
                                Command="{Binding DeselectPlotCommand}">
                            <TextBlock Text="&#x25B2;" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                        </Button>
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,24,8" Width="100">
                                <TextBlock Text="ИД ИМОТ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Plotid, StringFormat='#{0}'}"
                                           FontFamily="IBM Plex Mono, Consolas" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="120">
                                <TextBlock Text="НОМЕР НА ИМОТ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Plotnumber}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="120"
                                        IsVisible="{Binding SelectedPlot.Regulatedplotnumber, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="РЕГУЛИРАН №" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Regulatedplotnumber}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="160">
                                <TextBlock Text="ОБОЗНАЧЕНИЕ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Designation}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="120"
                                        IsVisible="{Binding SelectedPlot.City, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ГРАД" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.City}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="120"
                                        IsVisible="{Binding SelectedPlot.Municipality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ОБЩИНА" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Municipality}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140"
                                        IsVisible="{Binding SelectedPlot.Neighborhood, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="КВАРТАЛ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Neighborhood}" FontSize="12.5"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140"
                                        IsVisible="{Binding SelectedPlot.Street, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="УЛИЦА" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="12.5">
                                    <Run Text="{Binding SelectedPlot.Street}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding SelectedPlot.Streetnumber}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,8" Width="140"
                                        IsVisible="{Binding SelectedPlot.Locality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="МЕСТНОСТ" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedPlot.Locality}" FontSize="12.5"/>
                            </StackPanel>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="sm"
                                    Command="{Binding EditPlotCommand}"
                                    CommandParameter="{Binding SelectedPlot}">
                                &#x270F;&#xFE0F; Редактиране на имот
                            </Button>
                            <Button Classes="sm danger"
                                    Command="{Binding DeletePlotCommand}"
                                    CommandParameter="{Binding SelectedPlot}">
                                &#x1F5D1;&#xFE0F; Изтриване
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
